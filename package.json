{
  "name": "@xnetcat/transflow",
  "version": "1.1.0",
  "description": "Production-ready serverless file processing pipeline for AWS",
  "license": "MIT",
  "author": "xnetcat <xnetcat.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xnetcat/transflow.git"
  },
  "homepage": "https://github.com/xnetcat/transflow#readme",
  "bugs": {
    "url": "https://github.com/xnetcat/transflow/issues"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js",
      "require": "./dist/web/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "web": [
        "dist/web/index.d.ts"
      ]
    }
  },
  "bin": {
    "transflow": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "assets",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "aws",
    "lambda",
    "s3",
    "sqs",
    "ffmpeg",
    "serverless",
    "nextjs",
    "transcoding",
    "media",
    "ci",
    "github-actions"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1037.0",
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-ecr": "^3.1037.0",
    "@aws-sdk/client-iam": "^3.1037.0",
    "@aws-sdk/client-lambda": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@aws-sdk/credential-providers": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.6.2",
    "esbuild": "^0.28.0",
    "execa": "^8.0.1",
    "fast-glob": "^3.3.3",
    "jsonwebtoken": "^9.0.3",
    "ora": "^8.2.0",
    "semver": "^7.7.4",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/yargs": "^17.0.35",
    "aws-sdk-client-mock": "^4.1.0",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vitest": "3"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
